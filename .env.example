# ─── Required ───────────────────────────────────────────────────────────────
# Supabase Auth — public client credentials, safe to expose in the browser.
# Copy these into .env.local (gitignored) for local dev, and set them as
# environment variables in your host (e.g. Vercel) for production.
# Find them in: Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# ─── Future integrations (NOT yet wired up — leave unset) ─────────────────────
# Placeholders for features that are not implemented yet. The app runs without
# them. Never commit real secret values.
#
# Direct Postgres (if you later persist progress/content to the database):
#   DATABASE_URL=""
# Speech-to-text / AI:
#   OPENAI_API_KEY=""      # Whisper transcription for the speaking module
#   ANTHROPIC_API_KEY=""
# Payments:
#   STRIPE_SECRET_KEY=""
#   STRIPE_WEBHOOK_SECRET=""
#   NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
